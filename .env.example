# Application
NODE_ENV=development
PORT=3000

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=kairo

# Feature flags
ENABLE_SCORE_ON_INGEST=true
