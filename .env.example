# Application
NODE_ENV=development
HOST=localhost
PORT=8080
ENABLE_SWAGGER=true
SWAGGER_PATH=docs

# CORS — comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=kairo

# Feature flags
ENABLE_SCORE_ON_INGEST=true
ENABLE_AI_SCORING=false
ENABLE_AUTO_DRAFT_GENERATION=false
AUTO_DRAFT_SCORE_THRESHOLD=8

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-mini
OPENAI_REASONING_EFFORT=low
